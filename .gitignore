# Monorepo root ignore rules (Backend + Frontend)

# Dependencies
Backend/node_modules/
Frontend/node_modules/
**/node_modules/

# Environment files (keep only examples in git)
Backend/.env
Frontend/.env
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Build outputs
**/dist/
**/dist-ssr/
**/build/
**/.next/
**/out/

# Logs and reports
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# Coverage and cache
**/coverage/
**/.nyc_output/
**/.cache/
**/.vite/
**/.turbo/
**/.eslintcache
**/.parcel-cache/
**/.pnpm-store/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Temp files
**/*.tmp
**/*.temp
**/*.swp
**/*.sw?
**/*.local
**/*.pid

# Local sensitive scratch files
Backend/pass.txt

